{
	"extends": "../.nuxt/tsconfig.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": false,
		"noEmit": true,
		"types": ["node", "@playwright/test", "@nuxt/test-utils"],
		"paths": {
			"~~/*": ["./*"],
			"@@/*": ["./*"],
			"~/*": ["./src/*"],
			"@/*": ["./src/*"],
			"types/*": ["./src/shared/types/*"],
			"utils": ["./src/shared/utils/util"],
			"schemas": ["./src/shared/utils/schemas"],
			"stores/*": ["./src/stores/*"],
			"#test-utils/*": ["./tests/e2e/utils/*"]
		}
	},
	"include": ["./**/*.ts", "./**/*.spec.ts", "../src/shared/types/**/*.ts"],
	"comment": "unit/ has its own tsconfig (./unit/tsconfig.json) that extends the generated Nuxt app config for path aliases + ambient auto-imports; excluded here since this light e2e config lacks them",
	"exclude": ["../node_modules", "../.output", "../.nuxt", "../dist", "./unit"]
}

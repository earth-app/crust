{
  "name": "@earth-app/crust",
  "version": "0.4.0",
  "type": "module",
  "main": "./nuxt.config.ts",
  "files": [
    "src/components/",
    "src/composables/",
    "src/shared/",
    "src/stores/",
    "nuxt.config.ts",
    "tsconfig.json",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "dev": "bunx nuxi dev --dotenv .config/local.env --no-restart --public --port 3000",
    "dev:remote": "bunx nuxi dev --dotenv .config/production.env --dotenv .env --dotenv .env.local --no-restart --public --port 3000",
    "dev:test": "bunx nuxi dev --dotenv .config/test.env --no-restart --port 3000 --host 127.0.0.1",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "postinstall": "nuxt prepare",
    "prepack": "cp nuxt.config.library.ts nuxt.config.ts",
    "postpack": "git checkout nuxt.config.ts",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "prepare": "husky install",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:coverage": "COVERAGE=1 playwright test --project=chromium",
    "test:e2e:integration": "MOCK_DISABLED=1 playwright test",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:coverage:report": "bun tests/utils/coverage.ts",
    "test:mock-server": "bun tests/utils/mock-server.ts",
    "typecheck": "bunx vue-tsc --noEmit && bunx tsc --noEmit -p tests/tsconfig.json"
  },
  "dependencies": {
    "@earth-app/ocean": "1.0.3",
    "@internationalized/date": "^3.12.1",
    "@nuxt/hints": "^1.1.2",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.6",
    "@nuxt/scripts": "^1.1.1",
    "@nuxt/ui": "^4.8.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^6.0.0",
    "@nuxtjs/sitemap": "^8.0.15",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/luxon": "^3.7.1",
    "luxon": "^3.7.2",
    "nuxt": "^4.4.6",
    "nuxt-api-shield": "^0.10.2",
    "nuxt-schema-org": "^6.0.4",
    "nuxt-viewport": "^2.4.0",
    "piexifjs": "^1.0.6",
    "tailwindcss": "^4.3.0",
    "tailwindcss-motion": "^1.1.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "youtube-sr": "^4.3.12",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@nuxt/ui": "^4.5.0",
    "@nuxt/image": "^2.0.0"
  },
  "devDependencies": {
    "@codecov/nuxt-plugin": "^2.0.1",
    "@iconify-json/bx": "^1.2.3",
    "@iconify-json/carbon": "^1.2.22",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/circum": "^1.2.2",
    "@iconify-json/eos-icons": "^1.2.4",
    "@iconify-json/game-icons": "^1.2.4",
    "@iconify-json/healthicons": "^1.2.12",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/icon-park-outline": "^1.2.4",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/map": "^1.2.2",
    "@iconify-json/material-symbols": "^1.2.73",
    "@iconify-json/material-symbols-light": "^1.2.73",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/nimbus": "^1.2.1",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/solar": "^1.2.5",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@types/piexifjs": "^1.0.0",
    "@vue/test-utils": "^2.4.10",
    "estree-walker": "3.0.3",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "monocart-reporter": "^2.11.2",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "v8-to-istanbul": "^9.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1",
    "wrangler": "^4.93.1"
  },
  "lint-staged": {
    "*.{js,css,ts,json,yml,vue,md}": "prettier --write"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ]
}
